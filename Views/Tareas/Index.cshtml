@model IEnumerable<tl2_recupercionparcial2_2025_augusto_dip.ViewModels.TareaIndexViewModel>
@inject tl2_recupercionparcial2_2025_augusto_dip.Services.IAuthenticationService AuthService

@{
    ViewData["Title"] = "Listado de Tareas";
}

<h2 class="mb-4">Listado de Tareas</h2>

@if (AuthService.HasAccessLevel("Admin"))
{
    <p>
        <a asp-action="Alta" class="btn btn-success">Crear Nueva Tarea</a>
    </p>
}

<table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th>Título</th>
            <th>Descripción</th>
            <th>Complejidad</th>
            <th>Estado</th>
            
            @if (AuthService.HasAccessLevel("Admin"))
            {
                <th>Acciones</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Titulo</td>
                <td>@item.Descripcion</td>
                <td>@item.Complejidad</td>
                <td>
                    @if (item.Estado == "Realizada")
                    {
                        <span class="badge bg-success">@item.Estado</span>
                    }
                    else if (item.Estado == "Iniciada")
                    {
                        <span class="badge bg-warning text-dark">@item.Estado</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@item.Estado</span>
                    }
                </td>
                
                @if (AuthService.HasAccessLevel("Admin"))
                {
                    <td>
                        <a asp-action="Modificar" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Modificar</a>
                        <a asp-action="Borrar" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Borrar</a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>