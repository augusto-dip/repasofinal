@model tl2_recupercionparcial2_2025_augusto_dip.Models.Tarea

<h2>Eliminar Tarea</h2>

<h3 class="text-danger">¿Estás seguro de que querés borrar esta tarea?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Título</dt>
        <dd class="col-sm-10">@Model.Titulo</dd>

        <dt class="col-sm-2">Descripción</dt>
        <dd class="col-sm-10">@Model.Descripcion</dd>

        <dt class="col-sm-2">Complejidad</dt>
        <dd class="col-sm-10">@Model.Complejidad</dd>

        <dt class="col-sm-2">Estado</dt>
        <dd class="col-sm-10">@Model.Estado</dd>
    </dl>
    
    <form asp-action="Borrar" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirmar Borrado</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>