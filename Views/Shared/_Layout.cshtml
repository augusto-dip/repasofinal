@inject tl2_recupercionparcial2_2025_augusto_dip.Services.IAuthenticationService AuthService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - tl2_recupercionparcial2_2025_augusto_dip</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/tl2_recupercionparcial2_2025_augusto_dip.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <ul class="navbar-nav">
    @if (AuthService.IsAuthenticated())
    {
        <li class="nav-item">
            <span class="nav-link text-dark">Hola, @Context.Session.GetString("User")!</span>
        </li>
        <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" asp-controller="Login" asp-action="Logout">Deslogueo</a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link btn btn-outline-primary btn-sm" asp-controller="Login" asp-action="Index">Logueo</a>
        </li>
    }
</ul>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - tl2_recupercionparcial2_2025_augusto_dip - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
